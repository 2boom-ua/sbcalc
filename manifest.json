{
  "manifest_version": 3,
  "name": "Sidebar Calculator",
  "version": "1.3",
  "description": "Quick access calculator in the side panel",
  "author": "(c) 2boom 2026",
  "permissions": [
    "sidePanel",
    "storage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Calculator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "calc.html"
  }
}
